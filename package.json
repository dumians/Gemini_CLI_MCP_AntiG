        "test": "node --test tests/**/*.test.js"
    },
    "dependencies": {
        "@google/genai": "latest",
        "@modelcontextprotocol/sdk": "latest",
        "@google-cloud/spanner": "latest",
        "@google-cloud/bigquery": "latest",
        "oracledb": "latest",
        "pg": "^8.13.1",
        "dotenv": "^16.4.7"
    }
}