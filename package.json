{
    "name": "adk-multi-domain-demo",
    "version": "1.0.0",
    "description": "Enterprise Data Agents Demo across multiple DB domains",
    "main": "agent/index.js",
    "type": "module",
    "scripts": {
        "start": "node agent/index.js",
        "start-oracle-mcp": "node servers/oracle-mcp/index.js",
        "start-spanner-mcp": "node servers/spanner-mcp/index.js",
