# Dockerfile.mcp
# Generic Dockerfile for deploying domain-specific MCP agents to Cloud Run.

FROM node:20-slim

WORKDIR /app

# Copy root package.json for workspace dependencies if any
COPY package*.json ./
RUN npm install --production

# Copy the server and shared utilities
COPY servers/ ./servers/
COPY agent/utils/ ./agent/utils/

# Default to one of the servers - can be overridden via CMD or entrypoint
# But better to have individual ones or use an environment variable to pick.
# For simplicity, we'll suggest passing the server path as an argument.

EXPOSE 8080

# The actual command should be set per-deployment, e.g.:
# node servers/oracle-mcp/index.js
CMD ["node", "servers/oracle-mcp/index.js"]
