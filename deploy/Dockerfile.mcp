# Dockerfile.mcp
# Generic Dockerfile for deploying domain-specific MCP agents to Cloud Run.

FROM node:20-slim

WORKDIR /app

# Copy root package.json for workspace dependencies
COPY package*.json ./
RUN npm install --production

# Copy the server and shared utilities
COPY servers/ ./servers/
COPY agent/utils/ ./agent/utils/

# Default port for Cloud Run
EXPOSE 8080

# Use an environment variable to determine which server to run.
# Example: MCP_SERVICE=bigquery-mcp
ENV MCP_SERVICE=oracle-mcp

# Start the selected MCP server in SSE mode on the Cloud Run port
CMD node servers/${MCP_SERVICE}/index.js --sse --port 8080
