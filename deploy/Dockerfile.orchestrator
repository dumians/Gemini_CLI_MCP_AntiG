# Dockerfile.orchestrator
# Dockerfile for the Master Data Orchestrator (Backend).

FROM node:20-slim

WORKDIR /app

# Standard environment variables
ENV NODE_ENV=production
ENV PORT=8080

# Install dependencies for both agent and server
COPY package*.json ./
RUN npm install --production

COPY server/package*.json ./server/
RUN cd server && npm install --production

# Copy source code
COPY agent/ ./agent/
COPY server/ ./server/

EXPOSE 8080

WORKDIR /app/server
CMD ["node", "server.js"]
