GEMINI_API_KEY=your_api_key_here
PORT=3001

# --- Cloud Connectivity ---
# GCP Project
PROJECT_ID=your-gcp-project-id

# Spanner
SPANNER_INSTANCE=global-retail-instance
SPANNER_DATABASE=retail-db

# BigQuery
# (Uses PROJECT_ID by default)

# AlloyDB (PostgreSQL)
ALLOYDB_URL=postgresql://user:pass@localhost:5432/crm_db

# Oracle DB @ GCP
ORACLE_URL=your-oracle-connection-string
ORACLE_USER=system
ORACLE_PASS=password

# --- MCP Mesh Topology ---
# MCP Remote Endpoints (Optional if using local stdio)
ORACLE_MCP_URL=http://localhost:3003/sse
SPANNER_MCP_URL=http://localhost:3002/sse
BIGQUERY_MCP_URL=http://localhost:3004/sse
ALLOYDB_MCP_URL=http://localhost:3005/sse
HR_MCP_URL=http://localhost:3006/sse
