# --- Core Application Settings ---
GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001 # Port for the web server

# --- GCP Configuration (Required for all services) ---
GCP_PROJECT_ID=your-gcp-project-id

# --- Spanner Configuration ---
# Optional, defaults are provided in spanner-mcp/index.js
SPANNER_INSTANCE_ID=global-retail-instance
SPANNER_DATABASE_ID=global-retail-db

# --- BigQuery Configuration ---
# Optional, but recommended for query scoping
BIGQUERY_DATASET_ID=marketing_edw
BIGQUERY_LOCATION=EU # e.g., US, EU

# --- AlloyDB for PostgreSQL Configuration ---
ALLOYDB_REGION=your-alloydb-region # e.g., us-central1
ALLOYDB_CLUSTER=your-alloydb-cluster-id # e.g., crm-cluster
ALLOYDB_INSTANCE=your-alloydb-instance-name # e.g., crm-instance-1
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-secure-alloydb-password
ALLOYDB_DB=postgres

# --- Oracle DB@GCP Configuration ---
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECT_STRING=your-oracle-host:1521/your-service-name

# --- MCP Mesh Topology ---
# MCP Remote Endpoints (Optional if using local stdio)
ORACLE_MCP_URL=http://localhost:3003/sse
SPANNER_MCP_URL=http://localhost:3002/sse
BIGQUERY_MCP_URL=http://localhost:3004/sse
ALLOYDB_MCP_URL=http://localhost:3005/sse
HR_MCP_URL=http://localhost:3006/sse

# --- Authentication ---
JWT_SECRET=JWT_KEY_Example
ADMIN_USERNAME=UserName
ADMIN_PASSWORD=strong_pass!0rd
