{
    "mode": "local",
    "sources": {
        "oracle": {
            "name": "Oracle ERP",
            "domain": "Finance",
            "local": {
                "command": "node",
                "args": ["servers/oracle-mcp/index.js"],
                "transport": "stdio"
            },
            "remote": {
                "url": "${ORACLE_MCP_URL}",
                "transport": "sse"
            },
            "schema_file": "db-schemas/oracle_schema.sql",
            "health_check": "/health"
        },
        "spanner": {
